{
  "name": "decmpfs",
  "version": "0.2.0",
  "description": "Write files straight to OS transparent filesystem compression (APFS decmpfs / btrfs / NTFS) in one pass.",
  "license": "MIT",
  "repository": "https://github.com/decmpfs/decmpfs",
  "keywords": ["apfs", "btrfs", "compression", "decmpfs", "ntfs"],
  "main": "index.cjs",
  "types": "index.d.ts",
  "files": ["index.cjs", "index.d.ts"],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "registry": "https://registry.npmjs.org/"
  },
  "optionalDependencies": {
    "@decmpfs/darwin-arm64": "0.2.0",
    "@decmpfs/darwin-x64": "0.2.0",
    "@decmpfs/linux-arm64-gnu": "0.2.0",
    "@decmpfs/linux-x64-gnu": "0.2.0",
    "@decmpfs/win32-x64-msvc": "0.2.0"
  },
  "scripts": {
    "build": "node scripts/build.mts",
    "test": "node --test"
  }
}
